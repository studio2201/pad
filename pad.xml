<?xml version="1.0"?>
<Container version="2">
  <Name>pad</Name>
  <Repository>ghcr.io/studio2201/pad:latest</Repository>
  <Registry>https://ghcr.io/studio2201/pad</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/studio2201/pad/issues</Support>
  <Project>https://github.com/studio2201/pad</Project>
  <Overview>Lightweight, secure self-hosted markdown notepad and document editor built in Rust.</Overview>
  <Category>Productivity:Office Network:Web</Category>
  <WebUI>http://[IP]:[PORT:4402]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/studio2201/unraid-templates/master/templates/pad.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/studio2201/.github/master/profile/assets/pad.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Description>Lightweight, secure self-hosted markdown notepad and document editor built in Rust.</Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>4402</HostPort>
        <ContainerPort>4402</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/pad</HostDir>
      <ContainerDir>/config</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>4402</Value>
      <Name>PORT</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>/config</Value>
      <Name>DATA_DIR</Name>
      <Mode/>
    </Variable>
  </Environment>
  <Labels/>
  <Config Name="Web UI Port" Target="4402" Default="4402" Mode="tcp" Description="HTTP Web Interface Port" Type="Port" Display="always" Required="true" Mask="false">4402</Config>
  <Config Name="App Storage Directory" Target="/config" Default="/mnt/user/appdata/pad" Mode="rw" Description="Persistent data and configuration directory" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/pad</Config>
</Container>
